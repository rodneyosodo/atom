---
import { CONSOLE_BASE, CONSOLE_ROUTES } from "../lib/routes";
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Dashboard" } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || CONSOLE_BASE;
const sections = [...new Set(CONSOLE_ROUTES.map((route) => route.section))];
const isActive = (href: string) =>
  currentPath === href || (href !== CONSOLE_BASE && currentPath.startsWith(href));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} - Atom Console</title>
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar">
        <a class="brand" href={CONSOLE_BASE} aria-label="Atom Console dashboard">
          <span class="brand-mark">A</span>
          <span>
            <strong>Atom</strong>
            <small>API Builder</small>
          </span>
        </a>

        <nav class="nav" aria-label="Console navigation">
          {
            sections.map((section) => (
              <div class="nav-section">
                <div class="nav-heading">{section}</div>
                {CONSOLE_ROUTES.filter((route) => route.section === section).map((route) => (
                  <a class:list={["nav-link", { "is-active": isActive(route.href) }]} href={route.href}>
                    <span class="nav-dot" aria-hidden="true"></span>
                    <span>{route.label}</span>
                  </a>
                ))}
              </div>
            ))
          }
        </nav>
      </aside>

      <div class="workspace">
        <header class="topbar">
          <div>
            <span class="topbar-label">Atom Console</span>
            <strong>{title}</strong>
          </div>
          <div class="topbar-actions">
            <a href="/health">Health</a>
            <a href={`${CONSOLE_BASE}/playground`}>Playground</a>
          </div>
        </header>

        <main class="content">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
